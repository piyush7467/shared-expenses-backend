datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                  String                @id @default(uuid())
  email               String                @unique
  password            String
  name                String
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  memberships         Membership[]
  adminGroups         Group[]               @relation("GroupAdmin")
  paidExpenses        Expense[]             @relation("ExpensePayer")
  splits              ExpenseSplit[]
  settlementsPaid     Settlement[]          @relation("SettlementPayer")
  settlementsReceived Settlement[]          @relation("SettlementPayee")
  personalTransactions PersonalTransaction[]
}

model Group {
  id            String         @id @default(uuid())
  name          String
  description   String?
  inviteCode    String         @unique
  adminId       String?
  admin         User?          @relation("GroupAdmin", fields: [adminId], references: [id], onDelete: SetNull)
  createdAt     DateTime       @default(now())
  memberships   Membership[]
  expenses      Expense[]
  settlements   Settlement[]
  importReports ImportReport[]
}

model Membership {
  id       String    @id @default(uuid())
  userId   String
  groupId  String
  joinedAt DateTime  @default(now())
  leftAt   DateTime?
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  group    Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId, joinedAt])
}

enum SplitType {
  EQUAL
  EXACT
  PERCENTAGE
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

model Expense {
  id             String         @id @default(uuid())
  groupId        String
  payerId        String
  description    String
  originalAmount Decimal        @db.Decimal(12, 2)
  currency       String         // "INR" or "USD"
  exchangeRate   Decimal        @db.Decimal(10, 4) @default(1.0000)
  baseAmountINR  Decimal        @db.Decimal(12, 2)
  splitType      SplitType
  date           DateTime       @default(now())
  status         ApprovalStatus @default(APPROVED)
  createdAt      DateTime       @default(now())
  group          Group          @relation(fields: [groupId], references: [id], onDelete: Cascade)
  payer          User           @relation("ExpensePayer", fields: [payerId], references: [id], onDelete: Cascade)
  splits         ExpenseSplit[]
  anomalies      Anomaly[]
}

model ExpenseSplit {
  id         String   @id @default(uuid())
  expenseId  String
  userId     String
  amountOwed Decimal  @db.Decimal(12, 2)
  percentage Decimal? @db.Decimal(5, 2)
  expense    Expense  @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Settlement {
  id        String   @id @default(uuid())
  groupId   String
  payerId   String
  payeeId   String
  amount    Decimal  @db.Decimal(12, 2)
  date      DateTime @default(now())
  createdAt DateTime @default(now())
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  payer     User     @relation("SettlementPayer", fields: [payerId], references: [id], onDelete: Cascade)
  payee     User     @relation("SettlementPayee", fields: [payeeId], references: [id], onDelete: Cascade)
}

model ImportReport {
  id           String    @id @default(uuid())
  groupId      String
  fileName     String
  totalRows    Int
  importedRows Int
  failedRows   Int
  uploadedAt   DateTime  @default(now())
  group        Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  anomalies    Anomaly[]
}

enum AnomalyType {
  DUPLICATE_EXPENSE
  INVALID_DATE
  MISSING_USERS
  UNKNOWN_USERS
  NEGATIVE_AMOUNT
  INVALID_CURRENCY
  INVALID_SPLIT_PERCENTAGE
  SETTLEMENT_AS_EXPENSE
  EXPENSE_AFTER_LEFT
  EXPENSE_BEFORE_JOINED
  MISSING_PAYER
  MISSING_PARTICIPANTS
}

model Anomaly {
  id             String         @id @default(uuid())
  importReportId String?
  expenseId      String?
  type           AnomalyType
  description    String
  status         ApprovalStatus @default(PENDING)
  createdAt      DateTime       @default(now())
  importReport   ImportReport?  @relation(fields: [importReportId], references: [id], onDelete: Cascade)
  expense        Expense?       @relation(fields: [expenseId], references: [id], onDelete: Cascade)
}

enum TransactionType {
  EXPENSE
  INCOME
}

model PersonalTransaction {
  id             String          @id @default(uuid())
  userId         String
  type           TransactionType
  category       String
  amount         Decimal         @db.Decimal(12, 2)
  currency       String          // "INR" or "USD"
  exchangeRate   Decimal         @db.Decimal(10, 4) @default(1.0000)
  baseAmountINR  Decimal         @db.Decimal(12, 2)
  description    String?
  date           DateTime        @default(now())
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
}
